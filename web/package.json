{
  "name": "new-api-web-workspace",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "VITE_REACT_APP_VERSION=$(cat ../VERSION) bun run --cwd default dev -- --host 0.0.0.0 --port 3001",
    "dev:default": "VITE_REACT_APP_VERSION=$(cat ../VERSION) bun run --cwd default dev -- --host 0.0.0.0 --port 3001",
    "dev:classic": "VITE_REACT_APP_VERSION=$(cat ../VERSION) bun run --cwd classic dev -- --host 0.0.0.0 --port 3002",
    "build": "bun run build:default && bun run build:classic",
    "build:default": "bun run --cwd default build",
    "build:classic": "bun run --cwd classic build",
    "typecheck": "bun run --cwd default typecheck"
  },
  "workspaces": [
    "default",
    "classic"
  ],
  "catalog": {
    "@lobehub/icons": "^5.10.1",
    "@rsbuild/core": "^2.1.4",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rsbuild/plugin-tailwindcss": "^2.0.3",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "prettier": "^3.8.3",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sse.js": "^2.8.0"
  },
  "overrides": {
    "dompurify": "3.4.11",
    "form-data": "4.0.6",
    "hono": "4.12.31",
    "minimist": "1.2.8"
  }
}
