{
  "name": "new-api-web-workspace",
  "private": true,
  "scripts": {
    "dev": "bun run --cwd default dev",
    "dev:default": "bun run --cwd default dev",
    "dev:classic": "bun run --cwd classic dev",
    "build": "bun run build:default && bun run build:classic",
    "build:default": "bun run --cwd default build",
    "build:classic": "bun run --cwd classic build",
    "typecheck": "bun run --cwd default typecheck"
  },
  "workspaces": [
    "default",
    "classic"
  ],
  "catalog": {
    "@lobehub/icons": "^5.10.0",
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "prettier": "^3.8.3",
    "qrcode.react": "^4.2.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sse.js": "^2.8.0"
  }
}
